<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	    Sparkle.framework's helpers (Updater.app, Autoupdate, Downloader.xpc,
	    Installer.xpc) are signed by org.sparkle-project — a different team
	    than Whisperly. Hardened Runtime + Library Validation refuses to load
	    a framework whose Team ID doesn't match the host process's, so we
	    disable that specific check. Standard recipe for any Sparkle-2 app.
	    See https://sparkle-project.org/documentation/sandboxing/ and
	    https://developer.apple.com/documentation/bundleresources/entitlements/com_apple_security_cs_disable-library-validation
	-->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
</dict>
</plist>
