<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	    Sparkle 2 settings. These have to live here in Info.plist because the
	    INFOPLIST_KEY_* build setting only forwards a curated list of Apple
	    keys (NS* usage descriptions, CFBundle*, etc.). Custom third-party
	    keys like the SU* family are silently dropped if you try to set them
	    that way. Don't move them back into project.pbxproj.

	    SUFeedURL — public HTTPS URL of the appcast.xml. GitHub's
	      releases/latest/download/appcast.xml redirect always points at the
	      most recent release, so you only edit appcast.xml's contents per
	      release; this URL never changes.

	    SUPublicEDKey — EdDSA public key generated by scripts/sparkle-setup.sh.
	      Matches the private key stored in Keychain at
	      https://sparkle-project.org. Rotating this invalidates updates for
	      everyone running an existing build, so don't change it casually.
	-->
	<key>SUFeedURL</key>
	<string>https://github.com/krahim786/whisperly/releases/latest/download/appcast.xml</string>
	<key>SUPublicEDKey</key>
	<string>0IXMWOASnIti1nzFHoU+68wiLi3rskWCPvDbh9t5lgQ=</string>
	<key>SUEnableAutomaticChecks</key>
	<true/>
	<key>SUScheduledCheckInterval</key>
	<integer>86400</integer>
</dict>
</plist>
